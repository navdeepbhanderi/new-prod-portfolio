# AI chat widget — Google Gemini
# Get a free key at https://aistudio.google.com/apikey
# Without a key the widget falls back to the built-in static knowledge base.
GEMINI_API_KEY=
# Optional, defaults to gemini-2.5-flash
GEMINI_MODEL=

# Contact form — Gmail SMTP (App Password, not the account password)
# Create one at https://myaccount.google.com/apppasswords (needs 2FA enabled)
GMAIL_USER=work.navdeepbhanderi@gmail.com
GMAIL_APP_PASSWORD=
# Where inquiry notifications land (defaults to the profile email)
CONTACT_TO=navdeepbhanderi1@gmail.com
